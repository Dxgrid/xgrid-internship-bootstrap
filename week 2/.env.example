# Jenkins Credentials - Environment Variables for JCasC
# Copy this file to .env and populate with your actual credentials
# IMPORTANT: Never commit the .env file to git — it contains secrets!

# AWS Credentials (from your AWS account)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJalr...

# EC2 SSH Private Key (from your SSH key pair for EC2)
# Paste the entire PEM key between the markers below
EC2_SSH_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
MIIEowIBAAKCAQEA...
... (full private key content)
-----END RSA PRIVATE KEY-----
